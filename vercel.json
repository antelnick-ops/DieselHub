{
  "functions": {
    "api/webhook.js": {
      "maxDuration": 30
    },
    "api/poll-apg-tracking.js": {
      "maxDuration": 60
    },
    "api/create-checkout.js": {
      "includeFiles": "shared/**"
    },
    "api/freight-quote.js": {
      "includeFiles": "shared/**"
    }
  },
  "rewrites": [
    { "source": "/products/:sku", "destination": "/api/products/:sku" },
    { "source": "/sitemap.xml", "destination": "/api/sitemap.xml" }
  ]
}
